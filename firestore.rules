rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isMaster() {
      return hasProfile() && 
             (getUser(request.auth.uid).role == 'master' || 
              (request.auth.token.email == 'ridam.auditor@gmail.com' && request.auth.token.email_verified == true));
    }

    function isStoreAdmin(storeId) {
      return hasProfile() && ((getUser(request.auth.uid).role == 'admin' && getUser(request.auth.uid).storeId == storeId) || isMaster());
    }

    function isStoreMember(storeId) {
      return hasProfile() && ((getUser(request.auth.uid).storeId == storeId) || isMaster());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Stores
    match /stores/{storeId} {
      allow read: if isSignedIn(); // Any signed in user can see store info (for login/tenant identification)
      allow write: if isMaster();
    }

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email', 'role', 'status']) &&
               data.uid == userId &&
               data.role in ['master', 'admin', 'sales'] &&
               data.status in ['active', 'inactive'];
      }

      allow read: if isSignedIn() && (request.auth.uid == userId || isMaster());
      allow create: if isSignedIn() && request.auth.uid == userId && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role != 'master'; // Prevent self-promoting to master
      allow update: if isMaster() || 
                      (isSignedIn() && request.auth.uid == userId && 
                       request.resource.data.role == resource.data.role);
    }

    // Connection Test
    match /test/connection {
      allow read: if isSignedIn();
    }

    // Vehicles
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && isStoreMember(resource.data.storeId);
      allow list: if isSignedIn() && (isMaster() || resource.data.storeId == getUser(request.auth.uid).storeId);
      allow write: if isSignedIn() && isStoreMember(request.resource.data.storeId);
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isSignedIn() && isStoreMember(resource.data.storeId);
      allow list: if isSignedIn() && (isMaster() || resource.data.storeId == getUser(request.auth.uid).storeId);
      allow write: if isSignedIn() && isStoreMember(request.resource.data.storeId);
    }

    // Conversations
    match /conversations/{convId} {
      allow read: if isSignedIn() && isStoreMember(resource.data.storeId);
      allow list: if isSignedIn() && (isMaster() || resource.data.storeId == getUser(request.auth.uid).storeId);
      allow write: if isSignedIn() && isStoreMember(request.resource.data.storeId);
    }
  }
}
